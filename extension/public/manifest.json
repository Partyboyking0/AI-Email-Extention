{
  "manifest_version": 3,
  "name": "AI Email Automation Assistant",
  "description": "Summarize Gmail threads, generate replies, extract tasks, and classify urgency.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "identity", "notifications", "scripting"],
  "host_permissions": ["https://mail.google.com/*", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["assets/gmail.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Email Assistant",
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
